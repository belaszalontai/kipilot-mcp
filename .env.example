# KiCad runs as a separate GUI application. Start KiCad 9+ and open the project first.
# kicad-python reads these official variables when KiCad provides them.
# KICAD_API_SOCKET=
# KICAD_API_TOKEN=

KIPILOT_KICAD_CLIENT_NAME=kipilot-mcp
KIPILOT_KICAD_TIMEOUT_MS=60000
KIPILOT_LOG_LEVEL=INFO
# KIPILOT_LOG_FILE=.logs/kipilot-mcp.log
